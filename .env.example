# Propential — environment variables
# Copy to your Vercel Project → Settings → Environment Variables.
# The site runs fine with NONE of these set (the Apply form just shows the
# confirmation screen without sending anywhere). Add them to go live.

# ── Formstack (Apply form delivery) ──────────────────────────────────────
# Personal/OAuth access token with submission rights (Formstack → Account → API).
FORMSTACK_API_TOKEN=

# Numeric id of the destination Formstack form.
FORMSTACK_FORM_ID=

# OPTIONAL — JSON mapping OUR field names → Formstack numeric field ids.
# If omitted, edit DEFAULT_FIELD_MAP in api/apply.js instead.
# Example:
# FORMSTACK_FIELD_MAP={"name":"101","email":"102","phone":"103","amount":"104"}
FORMSTACK_FIELD_MAP=

# ── Google Maps (address autocomplete on Apply / Eligibility) ────────────
# Inactive until supplied. Also settable via <meta name="google-maps-key">.
# This one is PUBLIC (browser-side), so restrict it by HTTP referrer in GCP.
PROPENTIAL_MAPS_KEY=
