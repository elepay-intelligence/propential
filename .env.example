# ─── Propential backend env vars ───────────────────────────────────────────
# Copy patterns here; never commit real secrets. Locally, prefer:
#   vercel env pull .env.local
# which writes the real values (gitignored) for migrations + `vercel dev`.

# ── Neon Postgres ──
# Auto-injected by the Neon integration on Vercel. Used by Drizzle (db/client.ts)
# and drizzle-kit migrate/push/studio.
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# ── Formstack (v2025 API) ──
# Already added in Vercel (Production + Preview).
FORMSTACK_API_TOKEN=fs_pat_xxxxxxxxxxxxxxxxxxxx

# The "Reno Now" LIVE loan application form (encrypted) that apply.html posts to.
# NOTE: 59254464 (in Vercel) is a submissions-REPORT id, not a form id — the real
# live form is 4653616 ("LIVE APP FORM - Reno Now"). Update Vercel + this value.
FORMSTACK_FORM_ID=4653616

# Encryption password for the encrypted application form (X-FS-Encryption-Password).
FORMSTACK_USER_FORM_ENCRYPTION_PASSWORD=xxxxxxxxxxxx
